{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-supervisor.mjs",
    "dev:watch": "tsx watch src/index.ts",
    "build": "tsc && rm -rf dist/presets && cp -r src/presets dist/presets",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run src/services src/qa src/db/connection.test.ts src/db/repositories",
    "test:store-contract": "vitest run src/db/store-contract.test.ts",
    "test:store-contract:sql": "vitest run src/db/store-contract.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:bootstrap": "node --import tsx src/db/bootstrap.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "chat-turns:migrate": "node --import tsx src/scripts/migrate-agent-chat-turns.ts",
    "agents:sync": "node scripts/sync-agent-workspaces.mjs",
    "agents:validate": "node scripts/validate-agent-workspaces.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.7.4",
    "fastify-type-provider-zod": "^6.1.0",
    "node-cron": "^4.2.1",
    "openai": "^6.22.0",
    "otpauth": "^9.5.0",
    "postgres": "^3.4.9",
    "shared": "workspace:*",
    "ws": "^8.20.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.3.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0"
  }
}
