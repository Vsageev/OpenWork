{
  "name": "openwork",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:landing": "pnpm --filter landing dev",
    "dev:runner": "pnpm --filter openwork-runner dev",
    "dev:check": "bash scripts/check-processes.sh",
    "dev:clean": "bash scripts/check-processes.sh --kill --force",
    "db:bootstrap": "pnpm --filter backend db:bootstrap",
    "build": "pnpm -r run build",
    "build:backend": "pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "build:landing": "pnpm --filter landing build",
    "lint": "pnpm -r run lint",
    "lint:fix": "eslint --fix .",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:store-contract": "pnpm --filter backend test:store-contract",
    "test:reports": "vitest run packages/backend/test/agent-runs.routes.test.ts",
    "qa:board-run-comments": "tsx packages/backend/src/qa/board-qa-run-comments.ts",
    "smoke:runner-split": "node scripts/qa-runner-split-smoke.mjs",
    "verify": "pnpm typecheck && pnpm test && node scripts/verify-public-pages.mjs",
    "check": "pnpm lint && pnpm typecheck",
    "clean": "pnpm -r run clean",
    "prepare": "husky",
    "certs:generate": "bash scripts/generate-certs.sh",
    "docker:full": "docker compose --profile full up -d",
    "docker:full:stop": "docker compose --profile full stop",
    "docker:down": "docker compose --profile full down"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "bcrypt"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^3.2.4"
  }
}
